{
  "name": "chaoshub",
  "private": true,
  "version": "0.0.1",
  "description": "Browser-based platform for rapid multiplayer game creation",
  "scripts": {
    "dev": "pnpm --filter @chaoshub/web dev",
    "build": "pnpm --filter @chaoshub/web build",
    "preview": "pnpm --filter @chaoshub/web preview",
    "lint": "pnpm -r lint",
    "typecheck": "pnpm -r typecheck",
    "create-game": "node scripts/create-game.mjs"
  },
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=9.0.0"
  },
  "devDependencies": {
    "@typescript-eslint/eslint-plugin": "^8.60.0",
    "@typescript-eslint/parser": "^8.60.0",
    "eslint": "^10.4.1",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-vue": "^10.9.1",
    "prettier": "^3.8.3",
    "vue-eslint-parser": "^10.4.0"
  }
}
